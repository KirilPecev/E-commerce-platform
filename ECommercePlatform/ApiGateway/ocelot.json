  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "QoSOptions": {
      "ExceptionsAllowedBeforeBreaking": 3,
      "DurationOfBreak": 5000,
      "TimeoutValue": 2000
